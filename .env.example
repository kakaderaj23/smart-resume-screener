# Smart Resume Screener — Environment Configuration
# Copy this file to .env and replace placeholder values with your actual credentials.

# Database
DATABASE_URL=sqlite:///./smart_resume_screener.db

# Groq LLM Provider
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# xAI (Grok) LLM Provider (optional, alternative provider)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.5
